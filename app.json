{
  "expo": {
    "name": "FFC LotoTech25",
    "slug": "ffc-lototech25",
    "version": "1.0.17",
    "orientation": "portrait",
    "icon": "./assets/images/iconNovo.png",
    "scheme": "ffclototech25",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/iconNovo2.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ffc.lototech25",
      "versionCode": 17
    },
    "web": {
      "output": "static",
      "favicon": "./assets/faviconNovo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splashNovo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6333d78a-92c5-4ac5-ae66-7d7936414bb6"
      }
    }
  }
}
